{
  "name": "tyvok-studio-mvp",
  "version": "0.3.0",
  "private": true,
  "description": "Tyvok Studio commercial foundation with real serial G-code control",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json",
    "start": "electron .",
    "dist:win": "npm run build && electron-builder --win nsis portable",
    "dist:portable": "npm run build && electron-builder --win portable",
    "dist:nsis": "npm run build && electron-builder --win nsis",
    "dist:dir": "npm run build && electron-builder --win dir"
  },
  "dependencies": {
    "konva": "^9.3.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-konva": "^18.2.10",
    "zustand": "^4.5.5",
    "serialport": "^12.0.0",
    "@serialport/parser-readline": "^12.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^31.2.1",
    "typescript": "^5.5.4",
    "vite": "^5.3.4",
    "wait-on": "^8.0.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.tyvok.studio",
    "productName": "Tyvok Studio",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "public"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}